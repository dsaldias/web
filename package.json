{
  "name": "@dsaldias/auth-web",
  "version": "0.0.1",
  "description": "Sistema web de acceso RBAC — Vue 3 + Quasar",
  "productName": "Sistema web",
  "author": "Diego Saldias :) <sladiadev@gmail.com>",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style": "./dist/auth-web.css"
  },
  "files": [
    "dist",
    "src",
    "scripts"
  ],
  "bin": {
    "auth-web-init": "./scripts/init.mjs"
  },
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "dev:prepare": "quasar prepare"
  },
  "peerDependencies": {
    "@apollo/client": ">=3.8",
    "@vue/apollo-composable": ">=4.0",
    "graphql": ">=16",
    "graphql-ws": ">=5",
    "pinia": ">=2",
    "quasar": ">=2",
    "vue": ">=3.4",
    "vue-router": ">=4"
  },
  "dependencies": {
    "@apollo/client": "^3.8.6",
    "@quasar/cli": "^2.5.0",
    "@quasar/extras": "^1.16.4",
    "@types/crypto-js": "^4.2.2",
    "@types/leaflet": "^1.9.16",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "@vue/apollo-composable": "^4.0.0",
    "axios": "^1.2.1",
    "chart.js": "^4.4.7",
    "chartjs-plugin-datalabels": "^2.2.0",
    "crypto-js": "^4.2.0",
    "driver.js": "^1.3.6",
    "firebase": "^11.2.0",
    "graphql": "^16.8.1",
    "graphql-query-compress": "^1.2.4",
    "graphql-ws": "^5.14.0",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "pinia": "^2.0.11",
    "quasar": "^2.16.0",
    "register-service-worker": "^1.7.2",
    "vue": "^3.4.18",
    "vue-chart-3": "^3.1.8",
    "vue-leaflet": "^0.1.0",
    "vue-router": "^4.0.12",
    "vuefire": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.0.0",
    "@quasar/quasar-app-extension-apollo": "^2.2.3",
    "@types/node": "^20.5.9",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "~5.5.3",
    "vite-plugin-checker": "^0.8.0",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^2.0.29",
    "workbox-build": "^7.0.0",
    "workbox-cacheable-response": "^7.0.0",
    "workbox-core": "^7.0.0",
    "workbox-expiration": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
